discovery.docker "linux_containers" {
    host = "unix:///var/run/docker.sock"
    refresh_interval = "5s"
}

discovery.relabel "api_filter" {
    targets = discovery.docker.linux_containers.targets

    rule {
        source_labels = ["__meta_docker_container_name"]
        regex         = "^/?q-lens-orchestrator-api-1$"
        action        = "keep"
    }

    rule {
        target_label = "job"
        replacement  = "docker_logs"
    }

    rule {
        source_labels = ["__meta_docker_container_name"]
        target_label  = "container_name"
    }
}

loki.source.docker "api_logs" {
    host       = "unix:///var/run/docker.sock"
    targets    = discovery.relabel.api_filter.output
    forward_to = [loki.process.drop_noise.receiver]
}

loki.process "drop_noise" {
    forward_to = [loki.write.loki_push.receiver]

    stage.drop {
        source = "" // Inspect the whole log line
        expression = ".*GET /metrics.*"
    }
}

loki.write "loki_push" {
    endpoint {
        url = "http://loki:3100/loki/api/v1/push"
        batch_wait = "500ms"
        batch_size = "1KiB" 
    }
}